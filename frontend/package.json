{
  "name": "lithoscan-hud",
  "productName": "LithoScan HUD",
  "version": "1.0.0",
  "description": "Advanced Mining & Signature Overlay for Star Citizen",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.lithoscan.hud",
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!backend-bin"  
    ],
    "extraResources": [
      {
        "from": "backend-bin",
        "to": "backend-bin",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}